# Caddy sirve el cliente estatico por HTTP (sin TLS).
#
# El HTTPS publico y el certificado de confianza los provee CLOUDFLARE TUNNEL en
# el edge (ver ADR-0011); el origen solo necesita HTTP. Por eso aqui no hay `tls`
# ni redireccion: cloudflared enruta  https://<subdominio>.<dominio>  ->  este :80.
#
# Cabeceras COOP/COEP -> crossOriginIsolated -> habilita SharedArrayBuffer (WASM
# con hilos de MediaPipe). NOTA: si activas Rocket Loader / Auto Minify en
# Cloudflare para este hostname, pueden romper COEP; deshabilitalos para el.

{
	auto_https off
	admin off
}

:80 {
	root * /srv
	file_server
	encode gzip

	header {
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Embedder-Policy "require-corp"
		Cross-Origin-Resource-Policy "same-origin"
		-Server
	}
}
